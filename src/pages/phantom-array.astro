---
import Base from '../layouts/Base.astro';
import PhantomArray from '../components/benchmarks/PhantomArray.tsx';
import RelatedTools from '../components/layout/RelatedTools.astro';
import BenchmarkCTA from '../components/layout/BenchmarkCTA.astro';

const title = "Phantom Array Effect Test";
const description = "Test your display for the phantom array effect (stroboscopic stepping) during fast mouse movement.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": title,
  "url": "https://screenhz.com/phantom-array",
  "description": description,
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "Web Browser",
  "featureList": ["Interactive canvas benchmark"],
  "offers": { "@type": "Offer", "price": "0" }
};
---

<Base title={title} description={description} jsonLd={jsonLd}>
  <div class="bench-page" style="display: flex; flex-direction: column; height: 100vh; background: #0c0c0c; color: #e8e8e8; font-family: 'IBM Plex Mono', monospace;">
    <div class="bench-header" style="height: 48px; border-bottom: 1px solid #222; display: flex; align-items: center; padding: 0 24px; flex-shrink: 0;">
      <a href="/" class="bench-back" style="color: #555; text-decoration: none; margin-right: 16px;">← Back</a>
      <h1 class="bench-title" style="font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; margin: 0;">{title}</h1>
    </div>
    
    <div style="flex-grow: 1; display: flex; flex-direction: column; min-height: 0;">
      <PhantomArray client:load />
    </div>

    <section class="seo-article" style="padding: 32px 24px; max-width: 800px; margin: 0 auto; line-height: 1.6; color: #e8e8e8;">
      <h2 style="font-size: 20px; margin-bottom: 16px;">The Phantom Array Effect</h2>
      <p style="margin-bottom: 16px;">Also known as the stroboscopic effect, this occurs when a high-contrast object moves quickly across the screen, appearing as a series of discrete, repeating steps rather than a smooth blur.</p>
    </section>

    <RelatedTools category="motion" heading="More Motion Tests" />
  </div>
  <BenchmarkCTA message="See how your display handles motion? Run the full benchmark." />
</Base>
