---
import Base from '../layouts/Base.astro';
import VerticalScrolling from '../components/benchmarks/VerticalScrolling.tsx';

const title = "Vertical Scroll Smoothness Test";
const description = "Test how smoothly your monitor and browser can scroll text vertically. Identifies micro-stutters and frame drops.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Vertical Scroll Smoothness Test",
  "url": "https://screenhz.com/vertical-scrolling",
  "description": description,
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "Web Browser",
  "featureList": ["Micro-stutter detection", "Independent FPS columns", "Adjustable scroll speed"],
  "offers": { "@type": "Offer", "price": "0" }
};
---

<Base title={title} description={description} jsonLd={jsonLd}>
  <div class="bench-page" style="display: flex; flex-direction: column; height: 100vh; background: #0c0c0c; color: #e8e8e8; font-family: 'IBM Plex Mono', monospace;">
    <div class="bench-header" style="height: 48px; border-bottom: 1px solid #222; display: flex; align-items: center; padding: 0 24px; flex-shrink: 0;">
      <a href="/" class="bench-back" style="color: #555; text-decoration: none; margin-right: 16px;">← Back</a>
      <h1 class="bench-title" style="font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; margin: 0;">{title}</h1>
    </div>
    
    <div style="flex-grow: 1; display: flex; flex-direction: column; min-height: 0;">
      <VerticalScrolling client:load />
    </div>

    <section class="seo-article" style="padding: 32px 24px; max-width: 800px; margin: 0 auto; line-height: 1.6; color: #e8e8e8;">
      <h2 style="font-size: 20px; margin-bottom: 16px;">Vertical Scrolling Smoothness</h2>
      <p style="margin-bottom: 16px;">
        Smooth scrolling is essential for a pleasant web browsing and reading experience. When you scroll through a document or webpage,
        the text moves vertically across your screen. If your display or computer drops frames, the motion will appear to judder or skip,
        causing eye strain and disrupting readability.
      </p>
      
      <h3 style="font-size: 16px; margin-bottom: 12px; color: #555;">Stutter Detection</h3>
      <p style="margin-bottom: 16px;">
        This test features an automatic micro-stutter detector. If the browser fails to deliver a frame on time (taking more than 1.5x the expected frame time), 
        the column will flash a red border. This allows you to objectively measure browser rendering stability alongside display refresh rate.
      </p>

      <h3 style="font-size: 16px; margin-bottom: 12px; color: #555;">How to Read the Results</h3>
      <p style="margin-bottom: 16px;">
        The <strong>Smoothness Score</strong> starts at 100 and decreases for every detected stutter event. 
        Higher frame rates (120Hz, 144Hz, 240Hz+) will drastically improve text readability while in motion compared to standard 60Hz displays.
      </p>
    </section>
  </div>
</Base>
