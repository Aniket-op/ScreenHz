---
import Base from '../../layouts/Base.astro';

const title = "What is Mouse DPI? | Screen HZ Guides";
const description = "Learn what Mouse DPI means and how it affects your gaming precision and productivity.";

const article = {
  publishedTime: "2026-06-05T12:00:00Z",
  modifiedTime: new Date().toISOString(),
  author: "Screen HZ Team"
};
---

<Base title={title} description={description} article={article} ogType="article">
  <article class="py-24">
    <div class="container mx-auto px-4 max-w-3xl">
      <nav class="flex gap-2 text-xs font-bold uppercase tracking-widest text-muted mb-8">
        <a href="/" class="hover:text-brand">Home</a>
        <span>/</span>
        <a href="/guides" class="hover:text-brand">Guides</a>
        <span>/</span>
        <span class="text-brand">Mouse DPI</span>
      </nav>

      <h1 class="text-4xl md:text-5xl font-bold text-brand tracking-tighter mb-8 leading-tight">
        What is Mouse DPI?
      </h1>

      <div class="prose prose-invert max-w-none">
        <p class="text-lg text-muted leading-relaxed mb-6">
          DPI stands for Dots Per Inch. In the context of computer mice, it refers to the physical distance the mouse sensor detects relative to the cursor movement on your screen.
        </p>

        <h2 class="text-2xl font-bold text-brand mt-12 mb-4">How it affects your aim</h2>
        <p class="text-muted leading-relaxed mb-6">
          A higher DPI means your cursor moves further for the same physical mouse movement. While high DPI is often marketed as "better," most pro gamers prefer lower DPI (like 400 or 800) combined with higher in-game sensitivity for better control.
        </p>

        <div class="mt-16 p-8 bg-surface-elevated rounded-2xl border border-border text-center">
          <h3 class="text-2xl font-bold text-brand mb-4">Measure your DPI</h3>
          <p class="text-muted mb-8">Not sure what your mouse is set to? Use our estimator.</p>
          <a href="/#benchmarks" class="inline-block px-8 py-3 bg-brand text-bg font-bold rounded-full hover:bg-brand-muted transition-all">
            Open DPI Meter
          </a>
        </div>
      </div>
    </div>
  </article>
</Base>
