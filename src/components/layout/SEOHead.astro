---
export interface Props {
  title: string;
  description: string;
  slug: string;
  jsonLd?: any;
  ogImage?: string;
  keywords?: string;
  ogType?: string;
  robots?: string;
}
const { title, description, slug, jsonLd, ogImage, keywords, ogType = 'website', robots = 'index, follow, max-image-preview:large' } = Astro.props;
const canonicalUrl = `https://screenhz.com${slug}`;
const ogImg = ogImage || 'https://screenhz.com/og-image.png';
const fullTitle = `${title} | ScreenHz (Screen Hz) — Free Monitor & Display Benchmark`;

// Auto-generate BreadcrumbList for all non-home pages
const isHomePage = slug === '/' || slug === '';
const breadcrumbLd = isHomePage ? null : (() => {
  const segments = slug.replace(/\/$/, '').split('/').filter(Boolean);
  const items = [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://screenhz.com/' }
  ];
  if (segments.length === 1) {
    items.push({ '@type': 'ListItem', position: 2, name: title, item: canonicalUrl });
  } else if (segments.length >= 2) {
    // e.g. /guides/motion-blur → Home > Guides > Motion Blur
    const parentLabel = segments[0].charAt(0).toUpperCase() + segments[0].slice(1).replace(/-/g, ' ');
    items.push({ '@type': 'ListItem', position: 2, name: parentLabel, item: `https://screenhz.com/${segments[0]}` });
    items.push({ '@type': 'ListItem', position: 3, name: title, item: canonicalUrl });
  }
  return { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: items };
})();
---

<!-- Core Meta -->
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{fullTitle}</title>
<meta name="description" content={description} />
{keywords && <meta name="keywords" content={keywords} />}
<meta name="author" content="ScreenHz" />
<meta name="robots" content={robots} />
<meta name="theme-color" content="#080808" />
<link rel="canonical" href={canonicalUrl} />

<!-- Open Graph -->
<meta property="og:type"        content={ogType} />
<meta property="og:site_name"   content="ScreenHz" />
<meta property="og:title"       content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url"         content={canonicalUrl} />
<meta property="og:image"       content={ogImg} />
<meta property="og:image:width"  content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt"    content="ScreenHz — Monitor & Display Benchmark" />
<meta property="og:locale"       content="en_US" />

<!-- Twitter / X Card -->
<meta name="twitter:card"        content="summary_large_image" />
<meta name="twitter:site"        content="@screenhz" />
<meta name="twitter:title"       content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image"       content={ogImg} />
<meta name="twitter:image:alt"   content="ScreenHz — Monitor & Display Benchmark" />

<!-- Preconnect for performance -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="/icon.svg" />
<link rel="icon" type="image/png" href="/icon.png" />
<link rel="apple-touch-icon" href="/icon.png" />

<!-- JSON-LD Structured Data -->
{jsonLd && Array.isArray(jsonLd)
  ? jsonLd.map((schema: any) => <script type="application/ld+json" set:html={JSON.stringify(schema)} />)
  : jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
}

<!-- Auto BreadcrumbList -->
{breadcrumbLd && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />}

<!-- Base Website Schema -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "ScreenHz",
  "url": "https://screenhz.com",
  "description": "Free browser-based monitor benchmark and display test suite. Test refresh rate, motion blur, input latency, and more.",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://screenhz.com/?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
})} />

<!-- Theme init (prevent flash) -->
<script is:inline>
  (function() {
    try {
      const t = localStorage.getItem('screenhz-theme');
      if (t) document.documentElement.setAttribute('data-theme', t);
    } catch(e) {}
  })();
</script>
