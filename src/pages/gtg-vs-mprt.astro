---
import Base from '../layouts/Base.astro';
import GtGvsMPRT from '../components/benchmarks/GtGvsMPRT.tsx';
import RelatedTools from '../components/layout/RelatedTools.astro';
import BenchmarkCTA from '../components/layout/BenchmarkCTA.astro';

const title = "GtG vs MPRT Comparison";
const description = "Visualize the difference between pixel transition blur (GtG) and persistence blur (MPRT).";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": title,
  "url": "https://screenhz.com/gtg-vs-mprt",
  "description": description,
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "Web Browser",
  "featureList": ["Interactive canvas benchmark"],
  "offers": { "@type": "Offer", "price": "0" }
};
---

<Base title={title} description={description} jsonLd={jsonLd}>
  <div class="bench-page" style="display: flex; flex-direction: column; height: 100vh; background: #0c0c0c; color: #e8e8e8; font-family: 'IBM Plex Mono', monospace;">
    <div class="bench-header" style="height: 48px; border-bottom: 1px solid #222; display: flex; align-items: center; padding: 0 24px; flex-shrink: 0;">
      <a href="/" class="bench-back" style="color: #555; text-decoration: none; margin-right: 16px;">← Back</a>
      <h1 class="bench-title" style="font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; margin: 0;">{title}</h1>
    </div>
    
    <div style="flex-grow: 1; display: flex; flex-direction: column; min-height: 0;">
      <GtGvsMPRT client:load />
    </div>

    <section class="seo-article" style="padding: 32px 24px; max-width: 800px; margin: 0 auto; line-height: 1.6; color: #e8e8e8;">
      <h2 style="font-size: 20px; margin-bottom: 16px;">GtG vs MPRT Explained</h2>
      <p style="margin-bottom: 16px;">When evaluating monitor motion clarity, you will encounter two different metrics: <strong>Gray-to-Gray (GtG)</strong> and <strong>Moving Picture Response Time (MPRT)</strong>. While both are measured in milliseconds (ms), they measure entirely different aspects of display performance. GtG measures the physical speed of the pixels, while MPRT measures the persistence blur perceived by your eyes.</p>
      <h3 style="font-size: 16px; margin: 24px 0 12px; color: #ccc;">Gray-to-Gray (GtG)</h3>
      <p style="margin-bottom: 16px;">GtG measures the time it takes for a liquid crystal pixel to physically transition from one gray shade to another. If a pixel takes too long to change (e.g., 10ms), it will still be mid-transition when the next frame arrives, creating a visible smear or "ghosting" trail behind moving objects. Fast TN and modern IPS panels achieve 1ms GtG, while OLED panels achieve near-instantaneous 0.1ms GtG.</p>
      <h3 style="font-size: 16px; margin: 24px 0 12px; color: #ccc;">Moving Picture Response Time (MPRT)</h3>
      <p style="margin-bottom: 16px;">MPRT measures how long a pixel remains continuously visible on screen — the "sample-and-hold" time. Even if a pixel has a perfect 0ms GtG time (like an OLED), if the frame is held statically on screen for 16.7ms (at 60Hz), your eyes will still perceive motion blur as they track across the static image. The only way to lower MPRT is to increase the refresh rate (shorter frames) or use Black Frame Insertion (strobing the backlight to hide the hold time).</p>
    </section>

    <RelatedTools category="response" heading="Related Response Time Tests" />
  </div>
  <BenchmarkCTA message="Understand blur types? Get your full display performance score." />
</Base>
