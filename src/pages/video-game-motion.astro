---
import Base from '../layouts/Base.astro';
import VideoGameMotion from '../components/benchmarks/VideoGameMotion.tsx';

const title = "Video Game Motion Test";
const description = "Compare motion clarity in video games across different frame rates with our multi-lane simulation.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Video Game Motion Test",
  "url": "https://screenhz.com/video-game-motion",
  "description": description,
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "Web Browser",
  "featureList": ["Independent FPS lanes", "Motion blur simulation", "Checkerboard contrast patterns"],
  "offers": { "@type": "Offer", "price": "0" }
};
---

<Base title={title} description={description} jsonLd={jsonLd}>
  <div class="bench-page" style="display: flex; flex-direction: column; height: 100vh; background: #0c0c0c; color: #e8e8e8; font-family: 'IBM Plex Mono', monospace;">
    <div class="bench-header" style="height: 48px; border-bottom: 1px solid #222; display: flex; align-items: center; padding: 0 24px; flex-shrink: 0;">
      <a href="/" class="bench-back" style="color: #555; text-decoration: none; margin-right: 16px;">← Back</a>
      <h1 class="bench-title" style="font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; margin: 0;">{title}</h1>
    </div>
    
    <div style="flex-grow: 1; display: flex; flex-direction: column; min-height: 0;">
      <VideoGameMotion client:load />
    </div>

    <section class="seo-article" style="padding: 32px 24px; max-width: 800px; margin: 0 auto; line-height: 1.6; color: #e8e8e8;">
      <h2 style="font-size: 20px; margin-bottom: 16px;">Understanding Video Game Motion</h2>
      <p style="margin-bottom: 16px;">
        When playing video games, the frame rate (FPS) significantly impacts motion clarity and perceived smoothness. 
        Higher frame rates deliver a sharper image during fast motion, reducing the trailing blur effect inherent in sample-and-hold displays.
      </p>
      
      <h3 style="font-size: 16px; margin-bottom: 12px; color: #555;">How This Test Works</h3>
      <p style="margin-bottom: 16px;">
        This test uses three independent lanes running at user-selectable frame rates. The checkerboard pattern ensures high contrast, 
        making it easier to spot motion blur and judder. By adjusting the speed and comparing lanes, you can directly visualize the 
        difference between console-standard 30/60fps and high-refresh-rate 120/144fps targets.
      </p>

      <h3 style="font-size: 16px; margin-bottom: 12px; color: #555;">Motion Blur Overlay</h3>
      <p style="margin-bottom: 16px;">
        The "Blur Overlay" toggle visualizes the mathematical extent of persistence blur. Due to how your eyes track moving objects on a screen, 
        the image is dragged across your retina. The length of this blur is directly proportional to frame time (1/FPS) and movement speed.
      </p>
    </section>
  </div>
</Base>
