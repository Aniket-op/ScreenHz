---
import Base from '../layouts/Base.astro';
---

<Base title="404 — Page Not Found | ScreenHz" description="This page doesn't exist. Head back to the monitor benchmark suite." robots="noindex, nofollow">
  <div class="min-h-[60vh] flex flex-col items-center justify-center text-center px-4">
    <h1 class="text-9xl font-black text-brand tracking-tighter mb-4">404</h1>
    <p class="text-xl text-muted mb-8">Oops! This page has high input lag and failed to load.</p>
    <a href="/" class="px-8 py-3 bg-brand text-bg font-bold rounded-full hover:bg-brand-muted transition-all">
      Back to Benchmarks
    </a>
  </div>
</Base>
