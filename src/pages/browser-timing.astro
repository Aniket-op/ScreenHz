---
import Base from '../layouts/Base.astro';
import BrowserTimingPlot from '../components/benchmarks/BrowserTimingPlot.tsx';

const title = "Browser Animation Timing Precision";
const description = "Test your browser's requestAnimationFrame timing precision. Graph microsecond-level variance, frame jank, and animation scheduling accuracy at your monitor's refresh rate.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": title,
  "url": "https://screenhz.com/browser-timing",
  "description": description,
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "Web Browser",
  "featureList": ["Interactive canvas benchmark"],
  "offers": { "@type": "Offer", "price": "0" }
};
---

<Base title={title} description={description} jsonLd={jsonLd}>
  <div class="bench-page" style="display: flex; flex-direction: column; height: 100vh; background: #0c0c0c; color: #e8e8e8; font-family: 'IBM Plex Mono', monospace;">
    <div class="bench-header" style="height: 48px; border-bottom: 1px solid #222; display: flex; align-items: center; padding: 0 24px; flex-shrink: 0;">
      <a href="/" class="bench-back" style="color: #555; text-decoration: none; margin-right: 16px;">← Back</a>
      <h1 class="bench-title" style="font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; margin: 0;">{title}</h1>
    </div>
    
    <div style="flex-grow: 1; display: flex; flex-direction: column; min-height: 0;">
      <BrowserTimingPlot client:load />
    </div>

    <section class="seo-article" style="padding: 32px 24px; max-width: 800px; margin: 0 auto; line-height: 1.6; color: #e8e8e8;">
      <h2 style="font-size: 20px; margin-bottom: 16px;">Timer Precision and Jank</h2>
      <p style="margin-bottom: 16px;">Even if your monitor is perfectly smooth, the browser engine might drop frames or suffer from timer jitter due to CPU load, background tabs, or poor OS-level timer resolution. This scatter plot exposes that software-level instability.</p>
    </section>
  </div>
</Base>
