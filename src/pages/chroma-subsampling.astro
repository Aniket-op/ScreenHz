---
import Base from '../layouts/Base.astro';
import ChromaSubsampling from '../components/benchmarks/ChromaSubsampling.tsx';

const title = "Chroma Subsampling Test";
const description = "Test if your display or HDMI/DisplayPort cable is compressing color data using 4:2:2 or 4:2:0 chroma subsampling.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": title,
  "url": "https://screenhz.com/chroma-subsampling",
  "description": description,
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "Web Browser",
  "featureList": ["Interactive canvas benchmark"],
  "offers": { "@type": "Offer", "price": "0" }
};
---

<Base title={title} description={description} jsonLd={jsonLd}>
  <div class="bench-page" style="display: flex; flex-direction: column; height: 100vh; background: #0c0c0c; color: #e8e8e8; font-family: 'IBM Plex Mono', monospace;">
    <div class="bench-header" style="height: 48px; border-bottom: 1px solid #222; display: flex; align-items: center; padding: 0 24px; flex-shrink: 0;">
      <a href="/" class="bench-back" style="color: #555; text-decoration: none; margin-right: 16px;">← Back</a>
      <h1 class="bench-title" style="font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; margin: 0;">{title}</h1>
    </div>
    
    <div style="flex-grow: 1; display: flex; flex-direction: column; min-height: 0;">
      <ChromaSubsampling client:load />
    </div>

    <section class="seo-article" style="padding: 32px 24px; max-width: 800px; margin: 0 auto; line-height: 1.6; color: #e8e8e8;">
      <h2 style="font-size: 20px; margin-bottom: 16px;">What is Chroma Subsampling?</h2>
      <p style="margin-bottom: 16px;">Chroma subsampling is a video compression technique that reduces color (chroma) information at a lower resolution than brightness (luma) information. It exploits the fact that the human visual system is much more sensitive to differences in brightness than to differences in color. The most common formats are <strong>4:4:4</strong> (no compression — full color for every pixel), <strong>4:2:2</strong> (horizontal color resolution halved), and <strong>4:2:0</strong> (both horizontal and vertical color resolution halved, as used in HDMI 1.4 and most streaming video).</p>
      <h3 style="font-size: 16px; margin: 24px 0 12px; color: #ccc;">Why it Matters for PC Monitors</h3>
      <p style="margin-bottom: 16px;">Chroma subsampling is acceptable for video content (your eye doesn't notice halved color resolution in a moving scene), but it is <strong>catastrophic for PC desktop use</strong> and text rendering. When your display receives a 4:2:0 or 4:2:2 signal, colored text — especially at small font sizes — appears blurry, doubled, or with colored fringing. This commonly happens when a PC is connected to a TV or monitor via HDMI 1.4, which lacks the bandwidth for 4:4:4 at 4K/60Hz. The fix is usually switching to DisplayPort, or HDMI 2.0+ with proper driver settings.</p>
      <h3 style="font-size: 16px; margin: 24px 0 12px; color: #ccc;">How to Read the Test Results</h3>
      <p style="margin-bottom: 16px;">This test displays fine colored lines and patterns that are only clearly visible at 4:4:4 chroma. If you see blurred or merged colored stripes, your display connection is operating at 4:2:2 or 4:2:0. On NVIDIA GPUs, you can force 4:4:4 in the NVIDIA Control Panel under Display → Change Resolution → Output Color Format → RGB. On AMD, use Radeon Software → Display → Pixel Format → Full RGB. For TVs, ensure "PC Mode" or "HDMI Black Level: Full" is enabled in the display settings menu.</p>
    </section>
  </div>
</Base>
