---
import Base from '../layouts/Base.astro';
import HzDetector from '../components/benchmarks/HzDetector.tsx';

const title = "Exact Refresh Rate Test — Decimal Precision Hz Meter";
const description = "Test your exact monitor refresh rate with 4 decimal places of precision using our high-resolution browser Hz meter.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Exact Refresh Rate Test",
  "url": "https://screenhz.com/refresh-rate",
  "description": description,
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "Web Browser",
  "featureList": ["Sub-millisecond precision", "Frame time distribution graph", "Rolling average Hz"],
  "offers": { "@type": "Offer", "price": "0" }
};
---

<Base title={title} description={description} jsonLd={jsonLd}>
  <div class="bench-page">
    <div class="bench-header">
      <a href="/" class="bench-back">← Back</a>
      <h1 class="bench-title">{title}</h1>
      <p class="bench-subtitle">{description}</p>
    </div>
    
    <HzDetector client:load />

    <section class="seo-article">
      <h2>What is Screen Refresh Rate?</h2>
      <p>Refresh rate is the number of times per second your monitor or display updates with new images. It is measured in Hertz (Hz). A 60Hz display refreshes 60 times per second, while a 144Hz display refreshes 144 times per second.</p>
      
      <h3>Hz vs FPS Explained</h3>
      <p>While <strong>Refresh Rate (Hz)</strong> is a hardware specification of your monitor, <strong>Frames Per Second (FPS)</strong> is how fast your computer's graphics card can render new frames. For the smoothest experience, your FPS should match or exceed your monitor's Hz.</p>
      
      <h3>Why Exact Decimals Matter</h3>
      <p>Many "60Hz" monitors actually run at 59.94Hz due to legacy NTSC video standards. High-precision measurement helps debug stuttering issues and verify monitor overclocks by showing the exact microsecond timing of your display.</p>
    </section>
  </div>
</Base>
