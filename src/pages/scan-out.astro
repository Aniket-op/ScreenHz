---
import Base from '../layouts/Base.astro';
import ScanOut from '../components/benchmarks/ScanOut.tsx';

const title = "Scan-Out Pattern Test";
const description = "Visualize your monitor's frame scan-out pattern from top to bottom. Reveals the rolling shutter effect and helps diagnose tearing artifacts at different refresh rates.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": title,
  "url": "https://screenhz.com/scan-out",
  "description": description,
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "Web Browser",
  "featureList": ["Interactive canvas benchmark"],
  "offers": { "@type": "Offer", "price": "0" }
};
---

<Base title={title} description={description} jsonLd={jsonLd}>
  <div class="bench-page" style="display: flex; flex-direction: column; height: 100vh; background: #0c0c0c; color: #e8e8e8; font-family: 'IBM Plex Mono', monospace;">
    <div class="bench-header" style="height: 48px; border-bottom: 1px solid #222; display: flex; align-items: center; padding: 0 24px; flex-shrink: 0;">
      <a href="/" class="bench-back" style="color: #555; text-decoration: none; margin-right: 16px;">← Back</a>
      <h1 class="bench-title" style="font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; margin: 0;">{title}</h1>
    </div>
    
    <div style="flex-grow: 1; display: flex; flex-direction: column; min-height: 0;">
      <ScanOut client:load />
    </div>

    <section class="seo-article" style="padding: 32px 24px; max-width: 800px; margin: 0 auto; line-height: 1.6; color: #e8e8e8;">
      <h2 style="font-size: 20px; margin-bottom: 16px;">What is Display Scan-Out?</h2>
      <p style="margin-bottom: 16px;">Modern displays do not update the entire screen instantaneously. Instead, they receive data from the graphics card and draw the image line-by-line, typically from the top-left to the bottom-right. This process is called scan-out. At 60Hz, a full scan-out takes approximately 16.7 milliseconds. This means the bottom of your screen is physically displaying a slightly newer frame than the top of your screen at any given moment.</p>
      <h3 style="font-size: 16px; margin: 24px 0 12px; color: #ccc;">How Scan-Out Relates to Screen Tearing</h3>
      <p style="margin-bottom: 16px;">Screen tearing occurs when your graphics card sends a new frame to the monitor while the monitor is only halfway through scanning out the previous frame. The monitor simply begins drawing the new frame from wherever it currently is, resulting in a horizontal "tear" line where the top half shows frame A and the bottom half shows frame B. V-Sync solves this by forcing the GPU to wait for the monitor's vertical blanking interval (VBLANK) — the tiny pause after reaching the bottom before starting the next scan at the top.</p>
      <h3 style="font-size: 16px; margin: 24px 0 12px; color: #ccc;">How to See the Scan-Out Process</h3>
      <p style="margin-bottom: 16px;">Our eyes are generally too slow to perceive the scan-out process directly. However, if you point a high-speed camera (like the 240fps slow-motion mode on most modern smartphones) at this test pattern, you will clearly see a dark horizontal band rapidly traveling from the top of the monitor to the bottom. This is the physical drawing of the frame occurring in real time.</p>
    </section>
  </div>
</Base>
