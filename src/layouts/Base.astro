---
import '../styles/tokens.css';
import '../styles/global.css';
import '../styles/animations.css';
import SEOHead from '../components/layout/SEOHead.astro';
import Nav from '../components/layout/Nav.astro';
import Footer from '../components/layout/Footer.astro';

interface Props {
  title: string;
  description: string;
  jsonLd?: object;
}

const { title, description, jsonLd } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <SEOHead title={title} description={description} slug={Astro.url.pathname} jsonLd={jsonLd} />
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
