---
import Base from '../layouts/Base.astro';
import PhantomArray from '../components/benchmarks/PhantomArray.tsx';
import RelatedTools from '../components/layout/RelatedTools.astro';
import BenchmarkCTA from '../components/layout/BenchmarkCTA.astro';

const title = "Phantom Array Effect Test";
const description = "Test for the phantom array (saccadic stepping) effect. Reveals stroboscopic line illusions caused by fast eye saccades on high-refresh displays - a BFI and PWM artifact.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": title,
  "url": "https://screenhz.com/phantom-array",
  "description": description,
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "Web Browser",
  "featureList": ["Interactive canvas benchmark"],
  "offers": { "@type": "Offer", "price": "0" }
};
---

<Base title={title} description={description} jsonLd={jsonLd}>
  <div class="bench-page" style="display: flex; flex-direction: column; height: 100vh; background: #0c0c0c; color: #e8e8e8; font-family: 'IBM Plex Mono', monospace;">
    <div class="bench-header" style="height: 48px; border-bottom: 1px solid #222; display: flex; align-items: center; padding: 0 24px; flex-shrink: 0;">
      <a href="/" class="bench-back" style="color: #555; text-decoration: none; margin-right: 16px;">← Back</a>
      <h1 class="bench-title" style="font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; margin: 0;">{title}</h1>
    </div>
    
    <div style="flex-grow: 1; display: flex; flex-direction: column; min-height: 0;">
      <PhantomArray client:load />
    </div>

    <section class="seo-article" style="padding: 32px 24px; max-width: 800px; margin: 0 auto; line-height: 1.6; color: #e8e8e8;">
      <h2 style="font-size: 20px; margin-bottom: 16px;">The Phantom Array Effect (Stroboscopic Stepping)</h2>
      <p style="margin-bottom: 16px;">The Phantom Array effect — also known as stroboscopic stepping or saccadic phantom arrays — is a visual illusion that occurs when your eyes dart rapidly (a saccade) across a flickering or strobing light source. Instead of seeing a continuous blur, your brain perceives a trail of distinct, sharply separated, repeated images.</p>
      <h3 style="font-size: 16px; margin: 24px 0 12px; color: #ccc;">Why it Happens on Monitors</h3>
      <p style="margin-bottom: 16px;">This effect is most commonly seen on monitors that use Pulse-Width Modulation (PWM) to dim their backlights, or monitors utilizing Black Frame Insertion (BFI/Strobing) for motion blur reduction. Because the backlight is turning on and off hundreds of times per second, a fast eye movement catches the screen in its "on" state at several different positions across your retina, creating a dotted line or array of phantom cursors in your vision.</p>
      <h3 style="font-size: 16px; margin: 24px 0 12px; color: #ccc;">The High Mouse Polling Connection</h3>
      <p style="margin-bottom: 16px;">You can also see a similar stepping effect by rapidly shaking your mouse cursor across the screen. At 60Hz, you will see a trail of separated cursors spaced far apart. At 240Hz, the phantom cursors are packed much closer together. This visual stepping is one of the main reasons enthusiast gamers push for 1000Hz+ mouse polling rates paired with 360Hz+ monitors — higher refresh rates pack the stroboscopic steps closer together until the motion finally appears as a continuous, unbroken path to the human eye.</p>
    </section>

    <RelatedTools category="motion" heading="More Motion Tests" />
  </div>
  <BenchmarkCTA message="See how your display handles motion? Run the full benchmark." />
</Base>